{
  "expo": {
    "name": "istgah",
    "slug": "istgah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/istgah-logo.png",
    "scheme": "istgah",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohsendastaran.istgah"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/istgah-logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mohsendastaran.istgah",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/istgah-logo.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-status-bar",
      "expo-localization",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71d8e51b-cecb-44f8-b797-c7775db334fc"
      }
    },
    "owner": "mohsendastarans-team"
  }
}
